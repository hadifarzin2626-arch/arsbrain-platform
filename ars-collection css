/* 41. ARS COLLECTION — FEATURED COLLECTION CARDS          */
/* ========================================================= */


/* ========================================================= */
/* 41.1 — FEATURED GRID                                   */
/* ========================================================= */

.ars-collection-page
.featured-grid{

    display:grid;

    grid-template-columns:

        repeat(
            12,
            minmax(
                0,
                1fr
            )
        );

    gap:
        22px;

    perspective:
        1400px;

}


