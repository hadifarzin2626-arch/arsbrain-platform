.ars-collection-page
.feature-card-camera{

    top:
        28%;

    left:
        3%;

}


/* ========================================================= */
/* 37.5 — SENSOR CARD                                     */
/* ========================================================= */

.ars-collection-page
.feature-card-sensor{

    bottom:
        22%;

    right:
        20%;

}


/* ========================================================= */
/* 37.6 — ARS BRAIN CARD                                  */
/* ========================================================= */

.ars-collection-page
.feature-card-brain{

    top:
        10%;

    left:
        34%;

}


/* ========================================================= */
/* 38. ARS COLLECTION — SYSTEM SCAN                        */
/* ========================================================= */


/* ========================================================= */
/* 38.1 — SCAN LINE                                       */
/* ========================================================= */

.ars-collection-page
.collection-scan-line{

    position:absolute;

    left:
        8%;

    right:
        8%;

    height:
        1px;

    z-index:
        25;

    background:

        linear-gradient(
            90deg,
            transparent,
            rgba(196,154,85,.65),
            transparent
        );

    box-shadow:

        0 0 18px
        rgba(196,154,85,.45);

    opacity:
        0;

    animation:

        arsCollectionScan
        8s
        ease-in-out
        infinite;

}


/* ========================================================= */
/* 38.2 — SCAN ANIMATION                                  */
/* ========================================================= */

@keyframes arsCollectionScan{

    0%{

        top:
