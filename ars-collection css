    margin-top:
        28px;

    padding:
        52px;

    overflow:hidden;

    border-radius:
        26px;

}


/* ========================================================= */
/* 63.2 — BANNER ATMOSPHERE                                */
/* ========================================================= */

.ars-collection-page
.collection-banner::before{

    content:"";

    position:absolute;

    width:
        500px;

    height:
        500px;

    top:
        -280px;

    left:
        30%;

    border-radius:
        50%;

    background:

        radial-gradient(
            circle,
            rgba(
                196,
                154,
                85,
                .13
            ),
            transparent 70%
