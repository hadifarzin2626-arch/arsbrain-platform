    .collection-system-hud{

        left:
            3%;

        top:
            4%;

        width:
            190px;

    }

}


/* ========================================================= */
/* 39.1 — MOBILE FEATURE CARDS                            */
/* ========================================================= */

@media
(max-width:768px){

    .ars-collection-page
    .collection-feature-connections{

        display:none;

    }

    .ars-collection-page
    .feature-data-card{

        width:
            min(
                270px,
                calc(
                    100vw - 40px
                )
            );

    }

    .ars-collection-page
    .vehicle-feature-nav{

        display:none;

    }

    .ars-collection-page
    .collection-system-hud{

        width:
            170px;

        transform:
            scale(.85);

        transform-origin:
            top left;

    }

