            85,
            .12
        );

    transition:

        transform
        .5s
        cubic-bezier(
            .16,
            1,
            .3,
            1
        ),

        background
        .4s
        ease,

        box-shadow
        .4s
        ease;

}


.ars-collection-page
.gallery-video:hover
