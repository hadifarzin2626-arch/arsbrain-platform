    color:
        #fff;

    font-size:
        clamp(
            1.8rem,
            3vw,
            3rem
        );

    line-height:
        1.1;

    font-weight:
        500;

    letter-spacing:
        -.03em;

}


.ars-collection-page
.banner-content
p{

    max-width:
        760px;

    margin:
        0;

    color:

        rgba(
            255,
            255,
            255,
            .52
        );

    font-size:
        .76rem;

    line-height:
        1.85;

}


/* ========================================================= */
/* 63.4 — BANNER ACTIONS                                  */
/* ========================================================= */

.ars-collection-page
.banner-actions{

    position:relative;

    z-index:
        2;

    display:flex;

    justify-content:flex-end;

    flex-wrap:wrap;

    gap:
